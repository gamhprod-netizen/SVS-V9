rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return signedIn() && request.auth.token.role is string ? request.auth.token.role : 'choriste';
    }

    function isAdmin() {
      return role() == 'admin';
    }

    function isBureau() {
      return role() == 'bureau' || isAdmin();
    }

    function isChoriste() {
      return role() == 'choriste';
    }

    // Variante stricte pour comptes Firebase Auth avec custom claims:
    // admin  -> controle total
    // bureau -> ecriture du document central
    // choriste -> lecture seule du document central
    // Attention: comme l'app stocke encore un etat central unique, Firestore
    // ne peut pas verifier finement un paiement ou une suggestion choriste sans
    // decouper les donnees en collections separees.
    match /chorale/data/documents/main {
      allow read: if signedIn();
      allow write: if isBureau();
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isBureau());
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
