rules_version = '2';

// ════════════════════════════════════════════════════════════════
// RÈGLES DE SÉCURITÉ FIRESTORE — SVS-EEI Chorale App
// ════════════════════════════════════════════════════════════════
//
// DÉPLOIEMENT :
//   firebase deploy --only firestore:rules
//
// OU via la Console Firebase :
//   Firestore Database → Règles → coller ce contenu → Publier
//
// ARCHITECTURE :
//   Collection : chorale-svs
//   Document   : data  (document unique contenant toute l'application)
//
// ════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Document principal de l'application ──────────────────────
    // Accès en lecture et écriture pour TOUS les utilisateurs
    // (l'authentification est gérée dans l'application elle-même
    //  via les mots de passe des départements et des choristes).
    //
    // ⚠️  NOTE SÉCURITÉ : Ces règles sont permissives car l'application
    // gère sa propre authentification. Si vous activez Firebase Auth
    // à l'avenir, remplacez `allow read, write: if true;`
    // par `allow read, write: if request.auth != null;`
    // ─────────────────────────────────────────────────────────────
    match /chorale-svs/data {
      allow read, write: if true;
    }

    // ── Bloquer tout accès aux autres collections (sécurité) ─────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
